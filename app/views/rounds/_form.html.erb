<%= form_with model: round, class: "field is-horizontal mt-6" do |f| %>
  <%= f.text_field :title, class: "input control" %>

  <%= link_to "Cancel", rounds_path, class: "button control ml-2" %>
  <%= f.submit "Save", class: "button control ml-2" %>
<% end %>

<%= render "shared/errors", record: round %>
