<%= form_with model: [@round, task], class: "field is-horizontal mt-6" do |f| %>
  <%= f.text_field :title, class: "input" %>

  <%= link_to "Cancel", round_path(task.round), class: "button control ml-2" %>
  <%= f.submit "Save", class: "button control ml-2" %>
<% end %>

<%= render "shared/errors", record: task %>
